```html
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lời Chào Từ Bà T 🌸</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>

<style>
:root {
    --primary-pink: #ffafcc;
    --secondary-pink: #ffc8dd;
    --deep-pink: #fb6f92;
    --bg-color: #f8f9fa;
}

body {
    font-family: 'Segoe UI';
    background: var(--bg-color);
    background-image: radial-gradient(#ffafcc 0.5px, transparent 0.5px);
    background-size: 20px 20px;
    display:flex; justify-content:center; align-items:center;
    min-height:100vh; margin:0;
}

.container {
    width:90%; max-width:520px;
    background:white;
    padding:30px;
    border-radius:30px;
    border:4px solid var(--primary-pink);
    box-shadow:10px 10px 0 var(--secondary-pink);
    text-align:center;
}

.screen { display:none; }
.active { display:block; animation: fadeInUp 0.5s; }

h1 { color:var(--deep-pink); }
.btn {
    display:block;
    width:100%;
    padding:14px;
    margin:10px 0;
    background:var(--primary-pink);
    color:white;
    border:none;
    border-radius:15px;
    font-weight:bold;
    cursor:pointer;
    transition: all 0.2s ease;
}
.btn:hover { transform: translateY(-2px); background:var(--deep-pink); }

.back-link {
    display:inline-block;
    margin-top:15px;
    font-size:14px;
    color:#888;
    text-decoration:none;
}

#prophecy-result {
    margin-top:15px;
    padding:10px;
    border:2px dashed var(--deep-pink);
    border-radius:10px;
    background:#fff0f3;
    font-weight:bold;
}
</style>
</head>

<body>

<div class="container animate__animated animate__fadeIn">

<!-- STEP 1 -->
<div id="step1" class="screen active">
    <h1>Bà T. Say Hi 👋</h1>
    <p>Trước khi t nghỉ việc, chọn đúng team nhé!</p>

    <p id="countdown" style="font-weight:bold;color:#fb6f92;"></p>

    <button class="btn" onclick="goToStep('trade-choice')">Team Trade</button>
    <button class="btn" onclick="goToStep('asa-choice')">Team Asa</button>
    <button class="btn" onclick="goToStep('quiz')">🎯 Mini Quiz</button>
</div>

<!-- TRADE -->
<div id="trade-choice" class="screen">
    <h1>Trade Team</h1>
    <button class="btn" onclick="goToStep('trade-offline')">Offline</button>
    <button class="btn" onclick="goToStep('trade-online')">Online</button>
    <a href="javascript:void(0)" class="back-link" onclick="goToStep('step1')">← Quay lại</a>
</div>

<div id="trade-offline" class="screen">
    <h1>Trade Offline ☕</h1>
    <button class="btn" onclick="showWish('Chị Lan','Chúc chị luôn xinh đẹp và chốt đơn mỏi tay!')">Chị Lan</button>
    <button class="btn" onclick="showWish('Anh Tuấn','Chúc anh sớm có người yêu 😏')">Anh Tuấn</button>
    <a href="javascript:void(0)" class="back-link" onclick="goToStep('trade-choice')">← Quay lại</a>
</div>

<div id="trade-online" class="screen">
    <h1>Trade Online 💻</h1>
    <button class="btn" onclick="showWish('Team Online','Dù online nhưng vẫn nhớ nhau nhé!')">Xem lời chúc</button>
    <a href="javascript:void(0)" class="back-link" onclick="goToStep('trade-choice')">← Quay lại</a>
</div>

<!-- ASA -->
<div id="asa-choice" class="screen">
    <h1>Team Asa</h1>
    <button class="btn" onclick="goToStep('asa-offline')">Offline</button>
    <button class="btn" onclick="goToStep('asa-online')">Online</button>
    <a href="javascript:void(0)" class="back-link" onclick="goToStep('step1')">← Quay lại</a>
</div>

<div id="asa-offline" class="screen">
    <h1>Asa Offline</h1>
    <button class="btn" onclick="showWish('Team Asa','Chúc mọi người luôn đỉnh!')">Xem</button>
    <a href="javascript:void(0)" class="back-link" onclick="goToStep('asa-choice')">← Quay lại</a>
</div>

<div id="asa-online" class="screen">
    <h1>Asa Online 💻</h1>
    <button class="btn" onclick="showWish('Bạn Linh','Rất vui khi làm việc cùng bà!')">Bạn Linh</button>
    <a href="javascript:void(0)" class="back-link" onclick="goToStep('asa-choice')">← Quay lại</a>
</div>

<!-- QUIZ -->
<div id="quiz" class="screen">
    <h1>Mini Quiz 😏</h1>
    <p>T nghĩ sao về việc t nghỉ?</p>

    <button class="btn" onclick="quiz('Sai rồi 😏')">Vì chán</button>
    <button class="btn" onclick="quiz('Gần đúng 😌')">Vì phát triển</button>
    <button class="btn" onclick="quiz('Chuẩn luôn 😎')">Vì xứng đáng hơn</button>

    <div id="quiz-result"></div>

    <a href="javascript:void(0)" class="back-link" onclick="goToStep('step1')">← Quay lại</a>
</div>

<!-- WISH -->
<div id="wish-screen" class="screen">
    <h2 id="name"></h2>
    <p id="wish"></p>

    <button class="btn" onclick="prophecy()">🔮 Xem tiên tri</button>
    <div id="prophecy-result"></div>

    <button class="btn" style="background:#ff85a1;" onclick="gift()">🎁 Mở quà</button>

    <a href="javascript:void(0)" class="back-link" onclick="goBack()">← Quay lại</a>
</div>

</div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<script>
let prev = 'step1';

function goToStep(id){
    document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    prev = id;
}

function goBack(){
    goToStep('step1');
}

function showWish(name,text){
    document.getElementById('name').innerText = name;
    document.getElementById('wish').innerText = text;
    goToStep('wish-screen');
}

function prophecy(){
    const list=[
        "Tương lai sáng như đèn LED 😆",
        "Sắp có người bao ăn 😏",
        "Tiền sắp nhiều lên đó 💸",
        "Có người thích bà rồi 😌"
    ];
    let res=document.getElementById('prophecy-result');
    res.innerText=list[Math.floor(Math.random()*list.length)];
    res.classList.add('animate__animated','animate__tada');
}

function quiz(text){
    document.getElementById('quiz-result').innerText=text;
}

function gift(){
    alert("🎉 Chúc bà luôn vui vẻ, nhiều tiền, ít drama!");
    confetti({
        particleCount:150,
        spread:100
    });
}

// COUNTDOWN
const end = new Date("2026-04-28 17:00:00").getTime();
setInterval(()=>{
    let now=new Date().getTime();
    let d=end-now;
    if(d<0){
        document.getElementById('countdown').innerText="T nghỉ rồi 😎";
        return;
    }
    let days=Math.floor(d/(1000*60*60*24));
    let hours=Math.floor((d/(1000*60*60))%24);
    document.getElementById('countdown').innerText=`⏳ ${days} ngày ${hours} giờ nữa nghỉ`;
},1000);
</script>

</body>
</html>
```
